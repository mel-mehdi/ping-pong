# SETUP:
# 1. Copy this file: cp .env.example .env
# 2. Replace all "CHANGE_ME_" values with secure passwords (minimum 16 characters)
# 3. Never commit .env to git

# ====================================
# DATABASE
# ====================================
POSTGRES_USER=dbadmin_transcendence
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password_HERE_min_16_chars
POSTGRES_DB=transcendence
DATABASE_URL=postgresql://dbadmin_transcendence:CHANGE_ME_strong_db_password_HERE_min_16_chars@database:5432/transcendence

# ====================================
# DJANGO BACKEND
# ====================================
# Generate SECRET_KEY: python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'
SECRET_KEY=CHANGE_ME_generate_50_random_chars_django_secret_key_HERE
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,backend,nginx

# Django Admin (optional - for creating superuser automatically)
DJANGO_SUPERUSER_USERNAME=transcendence_admin
DJANGO_SUPERUSER_EMAIL=transcendence_admin@example.com
DJANGO_SUPERUSER_PASSWORD=CHANGE_ME_django_superuser_password_HERE_min_16_chars

# ====================================
# MONITORING
# ====================================
GRAFANA_ADMIN_USER=monitoring_operator
GRAFANA_PASSWORD=CHANGE_ME_grafana_admin_password_HERE_min_16_chars

# ====================================
# GOOGLE OAUTH (optional)
# ====================================
GOOGLE_OAUTH2_CLIENT_ID=
GOOGLE_OAUTH2_CLIENT_SECRET=
GOOGLE_OAUTH2_REDIRECT_URI=http://localhost/auth/google/callback

# ====================================
# REDIS & FRONTEND
# ====================================
REDIS_URL=redis://redis:6379/0
VITE_APP_NAME=PingPong
VITE_APP_VERSION=1.0.0
VITE_ENABLE_CHAT=true
VITE_ENABLE_TOURNAMENTS=true
