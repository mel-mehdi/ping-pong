# Database Configuration
POSTGRES_DB=your_database_name
POSTGRES_USER=your_database_user
POSTGRES_PASSWORD=your_database_password

# Grafana Configuration
GRAFANA_PASSWORD=your_secure_password_here

# Django Configuration
SECRET_KEY=your_django_secret_key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,backend,nginx

# Django Superuser
DJANGO_SUPERUSER_USERNAME=your_superuser_username
DJANGO_SUPERUSER_EMAIL=your_superuser_email
DJANGO_SUPERUSER_PASSWORD=your_superuser_password

# Google OAuth2
GOOGLE_OAUTH2_CLIENT_ID=your_google_oauth2_client_id
GOOGLE_OAUTH2_CLIENT_SECRET=your_google_oauth2_client_secret
GOOGLE_OAUTH2_REDIRECT_URI=http://localhost/auth/google/callback

# Database URL for Django
DATABASE_URL=postgresql://your_database_user:your_database_password@database:5432/your_database_name

# Redis Configuration
REDIS_URL=redis://redis:6379/0

# Frontend Configuration
VITE_APP_NAME=PingPong
VITE_APP_VERSION=1.0.0
VITE_ENABLE_CHAT=true
VITE_ENABLE_TOURNAMENTS=true