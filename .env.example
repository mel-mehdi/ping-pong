
# Devops
GRAFANA_ADMIN_USER=monitoring_operator
GRAFANA_PASSWORD=strong_password_16_Characters_Here

DATABASE_URL=postgresql://transcendence:strong_password_16_Characters_Here@db:5432/dbadmin_transcendence

# Backend
# Local development defaults (change for production)
POSTGRES_DB=dbadmin_transcendence
POSTGRES_USER=transcendence
POSTGRES_PASSWORD=strong_password_16_Characters_Here
SECRET_KEY=django-insecure-local-dev-change-me
DEBUG=True
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=Admin123!@#
GOOGLE_OAUTH2_CLIENT_ID=
GOOGLE_OAUTH2_CLIENT_SECRET=
GOOGLE_OAUTH2_REDIRECT_URI=https://localhost/auth/google/callback

# Frontend

# Frontend Environment Configuration

# API Endpoint
# By default the frontend will use the same origin for API requests (e.g. `/api/...`).
# No need to set VITE_BACKEND_URL - nginx proxies all requests appropriately

# Application
VITE_APP_NAME=PingPong
VITE_APP_VERSION=1.0.0

# Features
VITE_ENABLE_CHAT=true
VITE_ENABLE_TOURNAMENTS=true


