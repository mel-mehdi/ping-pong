{
    "annotations": { "list" : [] },
    "editable": true,
    "fiscalYearMonth": 0,
    "graphToolTip": 0,
    "links": [],
    "liveNow": false,
    "panels": [
        {
            "title:": "System Uptime & Health",
            "type": "stat",
            "gridPos": { "h": 4, "w": 12, "x": 0, "y": 0 },
            "targets": [
                {"exp": "up{job=\"backend\"}", "legendFormat": "Backend Status", "refId": "A"},
                {"exp": "up{job=\"postgres\"}", "legendFormat": "Postgres Status", "refId": "B"}
            ],
            "fieldConfig": {
                "defaults": {
                    "mappings": [
                        { "options": {
                            "0": { "color": "red", "text": "DOWN" },
                            "1": { "color": "green", "text": "UP" }
                        }, "type": "value"
                    }
                    ]
                }
            }
        },
        {
            "title:": "CPU Usage per Container",
            "type": "timeseries",
            "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
            "targets": [
                {
                    "expr": "rate(container_cpu_usage_seconds_total{name=~\".+\"}[5m]) * 100", "legendFormat": "{{name}}", "refId": "A"
                }
            ],
            "fieldConfig": {
                "defaults": { "unit": "percent" }
            }
        },
        {
            "title:": "Memory Usage (MB)",
            "type": "gauge",
            "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
            "targets": [
                {
                    "expr": "container_memory_usage_bytes{name=~\"django|postges|redis\"} / 1024 / 1024", "legendFormat": "{{name}}", "refId": "A"
                }
            ],
            "fieldConfig": {
                "defaults": { "min": 0, "max": 512, "unit": "mbytes" }
            }
        },
        {
            "title:": "Postgres Active Connections",
            "type": "stat",
            "gridPos": { "h": 4, "w": 6, "x": 0, "y": 12 },
            "targets": [
                {
                    "expr": "pg_stat_activity_count", "refId": "A"
                }
            ]
        },
        {
            "title:": "Redis Memory Usage",
            "type": "timeseries",
            "gridPos": { "h": 8, "w": 12, "x": 6, "y": 12 },
            "targets": [
                {
                    "expr": "redis_memory_usage_bytes", "legendFormat": "Used Bytes","refId": "A"
                }
            ],
            "fieldConfig": {
                "defaults": { "unit": "bytes" }
            }
        }
    ],
    "refresh": "10s",
    "schemaVersion": 36,
    "style": "dark",
    "tags": ["devops", "42"],
    "templating": { "list": [] },
    "time": { "from": "now-15m", "to": "now" },
    "timePicker": {},
    "timezone": "",
    "title": "FT_Transcendence_Infrastructure",
    "uid": "ft_trans_dash",
    "version": 1
}