* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

html {
    height: 100%;
}

body {
    min-height: 100vh;
    overflow-x: hidden;
    overflow-y: auto;
}

:root {
    --primary-color: #667eea;
    --primary-dark: #5568d3;
    --secondary-color: #764ba2;
    --success-color: #10b981;
    --danger-color: #ef4444;
    --warning-color: #f59e0b;
    --dark-bg: #1a1a2e;
    --light-bg: #f8f9fa;
    --border-color: #e5e7eb;
    --text-primary: #333;
    --text-secondary: #666;
    --shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
    --shadow-lg: 0 10px 25px rgba(0, 0, 0, 0.15);
    --bg-gradient-start: #667eea;
    --bg-gradient-end: #764ba2;
    --card-bg: #ffffff;
    --navbar-bg: #ffffff;
}

/* Dark Theme */
[data-theme="dark"] {
    --light-bg: #1a1a2e;
    --border-color: #333;
    --text-primary: #e0e0e0;
    --text-secondary: #a0a0a0;
    --bg-gradient-start: #4a5fc8;
    --bg-gradient-end: #5e3a7a;
    --card-bg: #1a1a2e;
    --navbar-bg: #0f0f1e;
    --dark-bg: #0f0f1e;
    --shadow: 0 4px 6px rgba(0, 0, 0, 0.3);
    --shadow-lg: 0 10px 25px rgba(0, 0, 0, 0.5);
}

body {
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    background: linear-gradient(135deg, var(--bg-gradient-start) 0%, var(--bg-gradient-end) 100%);
    min-height: 100vh;
    color: var(--text-primary);
    transition: background 0.3s ease, color 0.3s ease;
}

#app {
    min-height: 100vh;
    width: 100%;
}

/* Authentication Pages */
.auth-container {
    min-height: 100vh;
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 20px;
}

.auth-card {
    background: var(--card-bg);
    border-radius: 20px;
    padding: 40px;
    box-shadow: var(--shadow-lg);
    max-width: 450px;
    width: 100%;
    transition: background 0.3s ease;
}

.auth-header {
    text-align: center;
    margin-bottom: 30px;
}

.auth-header h1 {
    font-size: 2.5rem;
    color: var(--primary-color);
    margin-bottom: 10px;
}

.auth-header p {
    color: var(--text-secondary);
    font-size: 0.95rem;
}

.auth-form {
    display: flex;
    flex-direction: column;
    gap: 20px;
}

.form-group {
    display: flex;
    flex-direction: column;
    gap: 8px;
}

.form-group label {
    font-weight: 600;
    color: var(--text-primary);
    font-size: 0.9rem;
}

.form-group input,
.form-group textarea {
    padding: 12px 15px;
    border: 2px solid var(--border-color);
    border-radius: 8px;
    font-size: 1rem;
    transition: all 0.3s ease;
    font-family: inherit;
    background: var(--card-bg);
    color: var(--text-primary);
}

.form-group input:focus,
.form-group textarea:focus {
    outline: none;
    border-color: var(--primary-color);
    box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.1);
}

.form-group input:disabled,
.form-group textarea:disabled {
    background-color: var(--light-bg);
    cursor: not-allowed;
}

.form-options {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.9rem;
}

.checkbox-label {
    display: flex;
    align-items: center;
    gap: 8px;
    cursor: pointer;
}

.checkbox-label input[type="checkbox"] {
    width: 18px;
    height: 18px;
    cursor: pointer;
}

.link {
    color: var(--primary-color);
    text-decoration: none;
    font-weight: 600;
    transition: color 0.3s ease;
}

.link:hover {
    color: var(--primary-dark);
}

.btn {
    padding: 12px 24px;
    font-size: 1rem;
    border: none;
    border-radius: 8px;
    cursor: pointer;
    font-weight: 600;
    transition: all 0.3s ease;
    background: var(--light-bg);
    color: var(--text-primary);
}

.btn:hover:not(:disabled) {
    transform: translateY(-2px);
    box-shadow: var(--shadow);
}

.btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
}

.btn-primary {
    background: var(--primary-color);
    color: white;
}

.btn-primary:hover:not(:disabled) {
    background: var(--primary-dark);
}

.btn-secondary {
    background: var(--secondary-color);
    color: white;
}

.btn-secondary:hover:not(:disabled) {
    background: #6b3f8e;
}

.btn-block {
    width: 100%;
}

.btn-sm {
    padding: 8px 16px;
    font-size: 0.875rem;
}

.auth-footer {
    text-align: center;
    margin-top: 25px;
    padding-top: 25px;
    border-top: 1px solid var(--border-color);
    color: var(--text-secondary);
}

/* Navigation Bar */
.navbar {
    background: var(--navbar-bg);
    box-shadow: var(--shadow);
    position: sticky;
    top: 0;
    z-index: 100;
    transition: background 0.3s ease;
}

.nav-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    height: 70px;
}

.nav-brand h2 {
    color: var(--primary-color);
    font-size: 1.5rem;
}

.nav-menu {
    display: flex;
    list-style: none;
    gap: 30px;
    align-items: center;
}

.nav-menu a {
    color: var(--text-primary);
    text-decoration: none;
    font-weight: 500;
    transition: color 0.3s ease;
    padding: 8px 0;
}

.nav-menu a:hover,
.nav-menu a.active {
    color: var(--primary-color);
}

/* Theme toggle in navbar */
.nav-menu .theme-toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin: 0;
    vertical-align: middle;
}

.nav-menu li {
    display: flex;
    align-items: center;
}

/* Main Container */
.main-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 20px;
    width: 100%;
}

/* Dashboard */
.dashboard-header {
    text-align: center;
    margin-bottom: 40px;
    color: white;
}

.dashboard-header h1 {
    font-size: 2.5rem;
    margin-bottom: 10px;
}

.dashboard-header p {
    font-size: 1.2rem;
    opacity: 0.9;
}

.dashboard-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 25px;
    margin-bottom: 50px;
}

.dashboard-card {
    background: var(--card-bg);
    border-radius: 15px;
    padding: 30px;
    text-align: center;
    box-shadow: var(--shadow);
    transition: transform 0.3s ease, background 0.3s ease;
}

.dashboard-card:hover {
    transform: translateY(-5px);
}

.card-icon {
    font-size: 3rem;
    margin-bottom: 15px;
}

.dashboard-card h3 {
    color: var(--text-primary);
    margin-bottom: 10px;
    font-size: 1.2rem;
}

.dashboard-card p {
    color: var(--text-secondary);
}

.dashboard-card .btn {
    margin-top: 20px;
    display: inline-block;
}

.big-number {
    font-size: 2.5rem !important;
    font-weight: bold;
    color: var(--primary-color) !important;
    margin: 15px 0;
}

.sub-text {
    font-size: 0.9rem;
    color: var(--text-secondary);
}

.dashboard-section {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 25px;
    margin-bottom: 50px;
}

/* Card Component */
.card {
    background: var(--card-bg);
    border-radius: 15px;
    box-shadow: var(--shadow);
    overflow: hidden;
    transition: background 0.3s ease;
}

.card-header {
    padding: 20px 25px;
    border-bottom: 1px solid var(--border-color);
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.card-header h2 {
    font-size: 1.3rem;
    color: var(--text-primary);
}

.card-body {
    padding: 25px;
}

/* Error Messages */
.error-message {
    color: var(--danger-color);
    font-size: 0.85rem;
    margin-top: 5px;
    display: block;
    min-height: 1.2em;
}

.form-group input.error,
.form-group textarea.error {
    border-color: var(--danger-color);
}

/* Focus Styles for Accessibility */
*:focus-visible {
    outline: 3px solid var(--primary-color);
    outline-offset: 2px;
}

button:focus-visible,
a:focus-visible {
    outline: 3px solid var(--primary-color);
    outline-offset: 2px;
}

/* Skip to main content link for screen readers */
.skip-link {
    position: absolute;
    top: -40px;
    left: 0;
    background: var(--primary-color);
    color: white;
    padding: 8px;
    text-decoration: none;
    z-index: 1000;
}

.skip-link:focus {
    top: 0;
}

/* Leaderboard */
.leaderboard {
    display: flex;
    flex-direction: column;
    gap: 15px;
    list-style: none;
}

.leaderboard-item {
    display: flex;
    align-items: center;
    gap: 15px;
    padding: 15px;
    background: var(--light-bg);
    border-radius: 10px;
    transition: background 0.3s ease;
}

.leaderboard-item:hover {
    background: #e9ecef;
}

.rank {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: bold;
    background: var(--border-color);
    color: var(--text-primary);
}

.rank.gold {
    background: #fbbf24;
    color: white;
}

.rank.silver {
    background: #9ca3af;
    color: white;
}

.rank.bronze {
    background: #cd7f32;
    color: white;
}

.player-name {
    flex: 1;
    font-weight: 600;
}

.player-score {
    color: var(--primary-color);
    font-weight: bold;
}

/* Activity List */
.activity-list {
    display: flex;
    flex-direction: column;
    gap: 20px;
    list-style: none;
}

.activity-item {
    display: flex;
    gap: 15px;
    align-items: flex-start;
}

.activity-icon {
    font-size: 1.5rem;
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--light-bg);
    border-radius: 50%;
}

.activity-content {
    flex: 1;
}

.activity-text {
    color: var(--text-primary);
    margin-bottom: 5px;
}

.activity-time {
    font-size: 0.85rem;
    color: var(--text-secondary);
}

/* Profile Page */
.profile-container {
    display: grid;
    grid-template-columns: 300px 1fr;
    gap: 25px;
}

.profile-sidebar {
    display: flex;
    flex-direction: column;
    gap: 25px;
}

.profile-avatar {
    background: var(--card-bg);
    border-radius: 15px;
    padding: 30px;
    text-align: center;
    box-shadow: var(--shadow);
    transition: background 0.3s ease;
}

.avatar-circle {
    width: 120px;
    height: 120px;
    border-radius: 50%;
    background: var(--primary-color);
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 20px;
    font-size: 2.5rem;
    color: white;
    font-weight: bold;
}

.profile-stats {
    background: var(--card-bg);
    border-radius: 15px;
    padding: 25px;
    box-shadow: var(--shadow);
    transition: background 0.3s ease;
}

.profile-stats h3 {
    margin-bottom: 20px;
    color: var(--text-primary);
}

.stat-item {
    display: flex;
    justify-content: space-between;
    padding: 12px 0;
    border-bottom: 1px solid var(--border-color);
    margin: 0;
}

.stat-item:last-child {
    border-bottom: none;
}

.stat-label {
    color: var(--text-secondary);
    font-size: 0.9rem;
}

.stat-value {
    color: var(--primary-color);
    font-weight: bold;
    font-size: 1.1rem;
}

.profile-content {
    display: flex;
    flex-direction: column;
    gap: 25px;
}

.form-row {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
}

/* Match List */
.match-list {
    display: flex;
    flex-direction: column;
    gap: 15px;
    list-style: none;
}

.match-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 15px;
    border-radius: 10px;
    background: var(--light-bg);
}

.match-item.win {
    border-left: 4px solid var(--success-color);
}

.match-item.loss {
    border-left: 4px solid var(--danger-color);
}

.match-result {
    display: flex;
    align-items: center;
    gap: 15px;
}

.result-badge {
    padding: 5px 12px;
    border-radius: 5px;
    font-weight: bold;
    font-size: 0.8rem;
}

.match-item.win .result-badge {
    background: var(--success-color);
    color: white;
}

.match-item.loss .result-badge {
    background: var(--danger-color);
    color: white;
}

.match-info p {
    margin: 3px 0;
}

.match-opponent {
    font-weight: 600;
    color: var(--text-primary);
}

.match-score {
    color: var(--text-secondary);
    font-size: 0.9rem;
}

.match-date {
    color: var(--text-secondary);
    font-size: 0.85rem;
}

/* Game Page */
.game-page-container {
    display: flex;
    justify-content: center;
    align-items: center;
    height: calc(100vh - 70px);
    overflow: hidden;
    padding: 15px;
    background: linear-gradient(135deg, var(--background) 0%, var(--card-bg) 100%);
}

.game-wrapper {
    background: var(--card-bg);
    border-radius: 20px;
    padding: 15px;
    box-shadow: var(--shadow-lg);
    max-width: 1300px;
    width: 100%;
    max-height: 100%;
    overflow: auto;
    display: flex;
    flex-direction: column;
    transition: background 0.3s ease;
}

.game-header {
    text-align: center;
    margin-bottom: 8px;
}

.game-header h1 {
    font-size: 1.4rem;
    color: var(--primary-color);
    margin-bottom: 3px;
    font-weight: 700;
}

.game-header p {
    color: var(--text-secondary);
    font-size: 0.9rem;
}

.game-layout {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 15px;
    align-items: start;
    flex: 1;
    overflow: hidden;
}

.game-container {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
    padding: 15px;
    border-radius: 15px;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
}

#fullscreenArea:fullscreen {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background: #0f0f1e;
    padding: 40px;
    gap: 30px;
    width: 100vw;
    height: 100vh;
}

#fullscreenArea:fullscreen .score-board {
    font-size: 1.5rem;
    padding: 25px 50px;
    max-width: 90vw;
}

#fullscreenArea:fullscreen .player-score .score {
    font-size: 4rem;
}

#fullscreenArea:fullscreen #gameCanvas {
    width: 80vw !important;
    height: 60vh !important;
    max-width: 1200px !important;
    max-height: 700px !important;
}

#fullscreenArea:-webkit-full-screen {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background: #0f0f1e;
    padding: 40px;
    gap: 30px;
    width: 100vw;
    height: 100vh;
}

#fullscreenArea:-webkit-full-screen #gameCanvas {
    width: 80vw !important;
    height: 60vh !important;
    max-width: 1200px !important;
    max-height: 700px !important;
}

#gameCanvas {
    background: #0f0f1e;
    border: 3px solid var(--primary-color);
    border-radius: 12px;
    box-shadow: 0 0 30px rgba(102, 126, 234, 0.4), 0 8px 20px rgba(0, 0, 0, 0.3);
    max-width: 100%;
    width: 600px;
    height: 350px;
    display: block;
}

.game-over {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    background: var(--card-bg);
    padding: 40px;
    border-radius: 15px;
    text-align: center;
    box-shadow: var(--shadow-lg);
    min-width: 300px;
    border: 2px solid var(--border-color);
}

.game-over.hidden {
    display: none;
}

.game-over h2 {
    color: var(--primary-color);
    margin-bottom: 15px;
    font-size: 2rem;
}

.game-over p {
    color: var(--text-primary);
    font-size: 1.3rem;
    margin-bottom: 20px;
}

.game-over .btn {
    background: var(--primary-color);
    color: white;
}

.controls {
    display: flex;
    flex-direction: column;
    gap: 12px;
    min-width: 240px;
    max-width: 260px;
}

.score-board {
    display: flex;
    justify-content: space-around;
    gap: 30px;
    background: rgba(255, 255, 255, 0.05);
    backdrop-filter: blur(10px);
    padding: 12px 25px;
    border-radius: 15px;
    width: 100%;
    border: 2px solid rgba(102, 126, 234, 0.3);
}

.player-score {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 5px;
    flex: 1;
}

.player-score .label {
    color: rgba(255, 255, 255, 0.7);
    font-weight: 600;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 1px;
}

.player-score .score {
    color: var(--primary-color);
    font-size: 2rem;
    font-weight: bold;
    text-shadow: 0 0 20px rgba(102, 126, 234, 0.5);
}

.button-group {
    display: flex;
    flex-direction: column;
    gap: 8px;
}

.instructions {
    background: var(--light-bg);
    padding: 12px;
    border-radius: 12px;
    text-align: center;
    border: 2px solid var(--border-color);
}

.instructions h3 {
    color: var(--text-primary);
    margin-bottom: 10px;
    font-size: 1rem;
}

.instruction-row {
    display: flex;
    flex-direction: column;
    gap: 12px;
}

.instruction-row div {
    color: var(--text-secondary);
    font-size: 0.9rem;
    text-align: left;
}

.instruction-row strong {
    color: var(--primary-color);
}

/* Responsive Design */
@media (max-width: 768px) {
    .nav-menu {
        gap: 15px;
        font-size: 0.9rem;
    }
    
    .nav-container {
        padding: 0 15px;
    }

    .dashboard-header h1 {
        font-size: 2rem;
    }

    .dashboard-grid {
        grid-template-columns: 1fr;
        gap: 20px;
        margin-bottom: 40px;
    }

    .dashboard-section {
        grid-template-columns: 1fr;
        gap: 20px;
    }

    .dashboard-grid {
        grid-template-columns: 1fr;
    }

    .dashboard-section {
        grid-template-columns: 1fr;
    }

    .profile-container {
        grid-template-columns: 1fr;
    }

    .form-row {
        grid-template-columns: 1fr;
    }

    .game-wrapper {
        padding: 15px;
    }

    .game-layout {
        grid-template-columns: 1fr;
        align-items: center;
    }

    .game-container {
        width: 100%;
        padding: 15px;
    }

    #gameCanvas {
        width: 100%;
        height: auto;
        max-height: 400px;
    }

    .controls {
        width: 100%;
        max-width: 100%;
    }

    .score-board {
        flex-direction: row;
        justify-content: space-around;
    }

    .button-group {
        flex-direction: column;
    }

    .instruction-row {
        flex-direction: row;
        justify-content: space-around;
    }

    .instruction-row div {
        text-align: center;
    }

    .auth-card {
        padding: 30px 20px;
    }

    #gameCanvas {
        max-width: 100%;
        height: auto;
    }
}

@media (max-width: 480px) {
    .nav-container {
        flex-direction: row;
        flex-wrap: wrap;
        height: auto;
        padding: 10px;
        gap: 10px;
        justify-content: center;
    }
    
    .nav-brand {
        width: 100%;
        text-align: center;
        margin-bottom: 10px;
    }
    
    .nav-brand h2 {
        font-size: 1.2rem;
    }

    .nav-menu {
        flex-wrap: wrap;
        justify-content: center;
        gap: 10px;
        width: 100%;
    }
    
    .nav-menu li {
        flex: 0 0 auto;
    }
    
    .nav-menu a {
        font-size: 0.85rem;
        padding: 5px 10px;
    }

    .dashboard-header h1 {
        font-size: 1.5rem;
    }

    .auth-card {
        padding: 25px 15px;
    }
}

/* Loading States */
.loading {
    opacity: 0.6;
    pointer-events: none;
    position: relative;
}

.loading::after {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    width: 30px;
    height: 30px;
    margin: -15px 0 0 -15px;
    border: 3px solid var(--border-color);
    border-top-color: var(--primary-color);
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
}

@keyframes spin {
    to { transform: rotate(360deg); }
}

@keyframes slideIn {
    from {
        transform: translateX(100%);
        opacity: 0;
    }
    to {
        transform: translateX(0);
        opacity: 1;
    }
}

@keyframes slideOut {
    from {
        transform: translateX(0);
        opacity: 1;
    }
    to {
        transform: translateX(100%);
        opacity: 0;
    }
}

@keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
}

@media print {
    .navbar,
    .btn,
    .game-container,
    .controls {
        display: none;
    }

    body {
        background: white;
    }

    .card,
    .dashboard-card {
        box-shadow: none;
        border: 1px solid #ddd;
    }
}

/* Reduced Motion Support */
@media (prefers-reduced-motion: reduce) {
    *,
    *::before,
    *::after {
        animation-duration: 0.01ms !important;
        animation-iteration-count: 1 !important;
        transition-duration: 0.01ms !important;
    }
}

/* High Contrast Mode Support */
@media (prefers-contrast: high) {
    :root {
        --primary-color: #0000ff;
        --border-color: #000;
        --text-primary: #000;
        --text-secondary: #333;
    }

    .btn {
        border: 2px solid currentColor;
    }
}

/* Theme Toggle Button */
.theme-toggle {
    position: relative;
    width: 60px;
    height: 30px;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    border-radius: 30px;
    border: 2px solid rgba(255, 255, 255, 0.3);
    cursor: pointer;
    transition: background 0.3s ease, border-color 0.3s ease;
    padding: 0;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 6px;
}

[data-theme="dark"] .theme-toggle {
    background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
    border-color: rgba(102, 126, 234, 0.5);
}

.theme-toggle::before {
    content: '☀️';
    position: absolute;
    font-size: 16px;
    left: 5px;
    opacity: 1;
    transition: opacity 0.3s ease;
}

.theme-toggle::after {
    content: '🌙';
    position: absolute;
    font-size: 16px;
    right: 5px;
    opacity: 0.3;
    transition: opacity 0.3s ease;
}

[data-theme="dark"] .theme-toggle::before {
    opacity: 0.3;
}

[data-theme="dark"] .theme-toggle::after {
    opacity: 1;
}

.theme-toggle:hover {
    opacity: 0.9;
    transform: scale(1.05);
}

/* Auth pages theme toggle (no navbar) */
.auth-container .theme-toggle {
    position: fixed;
    bottom: 30px;
    right: 30px;
    z-index: 1000;
    box-shadow: var(--shadow-lg);
}

/* Hide fixed theme toggle when navbar exists */
body:has(.navbar) .theme-toggle:not(.nav-menu .theme-toggle) {
    display: none;
}

@media (max-width: 768px) {
    .theme-toggle {
        width: 50px;
        height: 50px;
        bottom: 20px;
        right: 20px;
    }
    
    .theme-icon {
        font-size: 1.5rem;
    }
}

/* ===== SPA PONG GAME STYLES ===== */

/* Home View */
.home-container {
    min-height: calc(100vh - 70px);
    padding: 20px;
}

.home-content {
    max-width: 1200px;
    margin: 0 auto;
}

/* Welcome Section */
.welcome-section {
    text-align: center;
    padding: 60px 20px;
    background: rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(10px);
    border-radius: 20px;
    margin-bottom: 40px;
}

.welcome-title {
    font-size: 3.5rem;
    color: white;
    margin-bottom: 15px;
    font-weight: 700;
    text-shadow: 0 2px 10px rgba(0, 0, 0, 0.3);
}

.welcome-text {
    font-size: 1.3rem;
    color: rgba(255, 255, 255, 0.9);
    max-width: 800px;
    margin: 0 auto;
    line-height: 1.6;
}

/* Section Styling */
.section-title {
    font-size: 2rem;
    color: white;
    margin-bottom: 25px;
    font-weight: 700;
    text-shadow: 0 2px 5px rgba(0, 0, 0, 0.2);
}

.section-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 25px;
}

/* Play Section */
.play-section {
    margin-bottom: 50px;
}

.play-options-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 25px;
}

.play-option-card {
    background: var(--card-bg);
    border: 2px solid var(--border-color);
    border-radius: 15px;
    padding: 35px 25px;
    cursor: pointer;
    transition: all 0.3s ease;
    box-shadow: var(--shadow);
    text-align: center;
}

.play-option-card:hover {
    transform: translateY(-8px);
    box-shadow: var(--shadow-lg);
    border-color: var(--primary-color);
}

.play-icon {
    font-size: 3.5rem;
    margin-bottom: 15px;
}

.play-option-card h3 {
    color: var(--text-primary);
    font-size: 1.5rem;
    margin-bottom: 10px;
}

.play-option-card p {
    color: var(--text-secondary);
    font-size: 1rem;
}

/* Tournament Preview Section */
.tournament-preview-section {
    margin-bottom: 50px;
}

.tournament-preview-card {
    background: var(--card-bg);
    border-radius: 15px;
    padding: 40px;
    box-shadow: var(--shadow);
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 30px;
}

.tournament-info h3 {
    color: var(--text-primary);
    font-size: 1.8rem;
    margin-bottom: 15px;
}

.tournament-info p {
    color: var(--text-secondary);
    font-size: 1.1rem;
    margin-bottom: 20px;
}

.tournament-features {
    list-style: none;
    padding: 0;
}

.tournament-features li {
    color: var(--text-secondary);
    font-size: 1rem;
    margin-bottom: 8px;
    padding-left: 5px;
}

/* Leaderboard Preview Section */
.leaderboard-preview-section {
    margin-bottom: 50px;
}

.leaderboard-preview-card {
    background: var(--card-bg);
    border-radius: 15px;
    padding: 30px;
    box-shadow: var(--shadow);
}

.leaderboard-header {
    display: grid;
    grid-template-columns: 80px 1fr 120px;
    gap: 15px;
    padding: 15px 20px;
    background: var(--light-bg);
    border-radius: 10px;
    margin-bottom: 15px;
    font-weight: 600;
    color: var(--text-secondary);
    font-size: 0.9rem;
    text-transform: uppercase;
}

.leaderboard-list {
    list-style: none;
    padding: 0;
    margin: 0;
}

.leaderboard-item {
    display: grid;
    grid-template-columns: 80px 1fr 120px;
    gap: 15px;
    padding: 15px 20px;
    background: var(--light-bg);
    border-radius: 10px;
    margin-bottom: 12px;
    transition: all 0.3s ease;
    align-items: center;
}

.leaderboard-item:hover {
    transform: translateX(5px);
    background: rgba(102, 126, 234, 0.1);
}

.leaderboard-item .rank {
    font-size: 1.2rem;
}

.leaderboard-item .player-name {
    font-weight: 600;
    color: var(--text-primary);
}

.leaderboard-item .player-score {
    color: var(--primary-color);
    font-weight: 600;
    text-align: right;
}

/* Profile Snapshot Section */
.profile-snapshot-section {
    margin-bottom: 50px;
}

.profile-snapshot-card {
    background: var(--card-bg);
    border-radius: 15px;
    padding: 40px;
    box-shadow: var(--shadow);
    display: flex;
    align-items: center;
    gap: 30px;
}

.profile-avatar .avatar-circle {
    width: 100px;
    height: 100px;
    border-radius: 50%;
    background: var(--primary-color);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 3rem;
    color: white;
}

.profile-info {
    flex: 1;
}

.profile-info h3 {
    color: var(--text-primary);
    font-size: 2rem;
    margin-bottom: 20px;
}

.profile-stats {
    display: flex;
    gap: 40px;
}

.stat-item {
    display: flex;
    flex-direction: column;
    gap: 5px;
}

.stat-label {
    color: var(--text-secondary);
    font-size: 0.9rem;
    text-transform: uppercase;
}

.stat-value {
    color: var(--primary-color);
    font-size: 1.8rem;
    font-weight: bold;
}

/* Extra Info Section */
.extra-info-section {
    margin-bottom: 50px;
}

.info-cards-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 20px;
}

.info-card-small {
    background: var(--card-bg);
    border: 2px solid var(--border-color);
    border-radius: 12px;
    padding: 25px;
    text-align: center;
    transition: all 0.3s ease;
    box-shadow: var(--shadow);
}

.info-card-small:hover {
    transform: translateY(-5px);
    border-color: var(--primary-color);
}

.info-icon {
    font-size: 2.5rem;
    margin-bottom: 12px;
}

.info-card-small h3 {
    color: var(--text-primary);
    font-size: 1.2rem;
    margin-bottom: 8px;
}

.info-card-small p {
    color: var(--text-secondary);
    font-size: 0.95rem;
}

/* Game Info Section */
.game-info-section {
    margin-bottom: 50px;
}

.game-info-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 25px;
}

.info-card {
    background: var(--card-bg);
    border-radius: 15px;
    padding: 30px;
    box-shadow: var(--shadow);
    transition: all 0.3s ease;
}

.info-card:hover {
    transform: translateY(-5px);
    box-shadow: var(--shadow-lg);
}

.info-card h3 {
    color: var(--text-primary);
    font-size: 1.3rem;
    margin-bottom: 12px;
}

.info-card p {
    color: var(--text-secondary);
    line-height: 1.6;
}

/* Game View */
.game-view {
    min-height: 100vh;
    padding: 20px;
    display: flex;
    flex-direction: column;
}

.game-header-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 20px;
    padding: 15px 20px;
    background: var(--card-bg);
    border-radius: 15px;
    box-shadow: var(--shadow);
}

.game-header-bar h2 {
    color: var(--text-primary);
    margin: 0;
}

.btn-back {
    background: var(--light-bg);
    color: var(--text-primary);
    border: 1px solid var(--border-color);
}

.game-mode-badge {
    background: var(--primary-color);
    color: white;
    padding: 8px 16px;
    border-radius: 20px;
    font-size: 0.9rem;
    font-weight: 600;
}

.game-content {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
}

.score-display {
    display: flex;
    align-items: center;
    gap: 40px;
    background: var(--card-bg);
    padding: 20px 50px;
    border-radius: 15px;
    box-shadow: var(--shadow);
}

.player-score-box {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
}

.player-label {
    font-size: 1rem;
    color: var(--text-secondary);
    font-weight: 600;
    text-transform: uppercase;
}

.score-number {
    font-size: 3rem;
    font-weight: bold;
    color: var(--primary-color);
}

.score-divider {
    font-size: 2rem;
    color: var(--text-secondary);
}

.canvas-container {
    position: relative;
    background: #0f0f1e;
    border-radius: 15px;
    padding: 20px;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.3);
}

#pongCanvas {
    display: block;
    border: 3px solid var(--primary-color);
    border-radius: 10px;
    box-shadow: 0 0 30px rgba(102, 126, 234, 0.4);
}

.game-message {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    background: rgba(0, 0, 0, 0.9);
    color: white;
    padding: 30px 50px;
    border-radius: 15px;
    font-size: 1.5rem;
    text-align: center;
    display: none;
    z-index: 10;
    min-width: 300px;
}

.game-over-content {
    display: flex;
    flex-direction: column;
    gap: 20px;
    align-items: center;
}

.game-over-content h2 {
    font-size: 2.5rem;
    margin: 0;
}

.game-over-content p {
    margin: 0;
    font-size: 1.2rem;
}

.game-controls-info {
    display: flex;
    gap: 30px;
    background: var(--card-bg);
    padding: 15px 30px;
    border-radius: 10px;
    box-shadow: var(--shadow);
}

.control-item {
    color: var(--text-secondary);
    font-size: 0.95rem;
}

.control-item strong {
    color: var(--primary-color);
}

/* Tournament Setup */
.tournament-setup {
    min-height: 100vh;
    padding: 20px;
}

.tournament-header {
    display: flex;
    align-items: center;
    gap: 20px;
    margin-bottom: 30px;
    padding: 20px;
    background: var(--card-bg);
    border-radius: 15px;
    box-shadow: var(--shadow);
}

.tournament-header h1 {
    color: var(--text-primary);
    margin: 0;
    flex: 1;
    text-align: center;
}

.tournament-setup-content {
    max-width: 800px;
    margin: 0 auto;
    background: var(--card-bg);
    padding: 40px;
    border-radius: 20px;
    box-shadow: var(--shadow-lg);
}

.setup-instructions {
    text-align: center;
    margin-bottom: 40px;
}

.setup-instructions h2 {
    color: var(--primary-color);
    margin-bottom: 10px;
}

.setup-instructions p {
    color: var(--text-secondary);
}

.player-input-section {
    margin-bottom: 30px;
}

.player-inputs {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-bottom: 20px;
    max-height: 400px;
    overflow-y: auto;
    padding-right: 10px;
}

.player-input-group {
    display: flex;
    align-items: center;
    gap: 12px;
    background: var(--light-bg);
    padding: 12px;
    border-radius: 10px;
}

.player-number {
    font-weight: bold;
    color: var(--primary-color);
    min-width: 35px;
}

.player-name-input {
    flex: 1;
    padding: 10px 15px;
    border: 2px solid var(--border-color);
    border-radius: 8px;
    font-size: 1rem;
    background: var(--card-bg);
    color: var(--text-primary);
}

.player-name-input:focus {
    outline: none;
    border-color: var(--primary-color);
}

.btn-remove {
    background: var(--danger-color);
    color: white;
    border: none;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    font-size: 1.5rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    line-height: 1;
}

.btn-remove:hover {
    background: #dc2626;
}

.setup-actions {
    text-align: center;
}

.btn-large {
    padding: 15px 50px;
    font-size: 1.2rem;
    margin-bottom: 15px;
}

.player-count {
    color: var(--text-secondary);
    font-size: 0.95rem;
}

/* Tournament Play */
.tournament-play {
    min-height: 100vh;
    padding: 20px;
}

.tournament-progress {
    background: rgba(102, 126, 234, 0.2);
    padding: 8px 20px;
    border-radius: 20px;
    font-weight: 600;
    color: var(--primary-color);
}

.tournament-content {
    display: grid;
    grid-template-columns: 350px 1fr;
    gap: 20px;
    margin-top: 20px;
}

.match-info-panel {
    display: flex;
    flex-direction: column;
    gap: 20px;
}

.current-match-card,
.next-match-card {
    background: var(--card-bg);
    padding: 25px;
    border-radius: 15px;
    box-shadow: var(--shadow);
}

.current-match-card h3,
.next-match-card h3 {
    color: var(--text-primary);
    margin-bottom: 15px;
    font-size: 1.2rem;
}

.match-players {
    display: flex;
    flex-direction: column;
    gap: 15px;
    align-items: center;
}

.match-player {
    background: var(--primary-color);
    color: white;
    padding: 15px 25px;
    border-radius: 10px;
    font-weight: bold;
    font-size: 1.1rem;
    text-align: center;
    width: 100%;
}

.vs-text {
    font-weight: bold;
    color: var(--text-secondary);
    font-size: 1.5rem;
}

.match-players-small {
    display: flex;
    flex-direction: column;
    gap: 8px;
    text-align: center;
    color: var(--text-secondary);
}

.match-players-small span:first-child,
.match-players-small span:last-child {
    font-weight: 600;
    color: var(--text-primary);
}

.tournament-bracket-preview {
    background: var(--card-bg);
    padding: 20px;
    border-radius: 15px;
    box-shadow: var(--shadow);
}

.tournament-bracket-preview h4 {
    color: var(--text-primary);
    margin-bottom: 15px;
}

.bracket-match {
    padding: 12px;
    background: var(--light-bg);
    border-radius: 8px;
    margin-bottom: 10px;
    font-size: 0.9rem;
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
}

.bracket-match.active {
    background: rgba(102, 126, 234, 0.2);
    border-left: 4px solid var(--primary-color);
}

.bracket-match.completed {
    opacity: 0.6;
}

.match-status {
    font-weight: bold;
    min-width: 20px;
}

.bracket-player {
    color: var(--text-primary);
}

.bracket-vs {
    color: var(--text-secondary);
    font-size: 0.8rem;
}

.winner-badge {
    color: var(--success-color);
    font-weight: bold;
    font-size: 0.85rem;
}

.game-area {
    display: flex;
    flex-direction: column;
    gap: 20px;
    align-items: center;
}

/* Tournament Results */
.tournament-results {
    min-height: 100vh;
    padding: 20px;
}

.champion-banner {
    background: linear-gradient(135deg, var(--primary-color) 0%, var(--secondary-color) 100%);
    color: white;
    padding: 60px 40px;
    border-radius: 20px;
    text-align: center;
    margin-bottom: 40px;
    box-shadow: var(--shadow-lg);
}

.champion-banner h1 {
    font-size: 3rem;
    margin-bottom: 20px;
    text-shadow: 0 2px 10px rgba(0, 0, 0, 0.3);
}

.champion-name {
    font-size: 4rem;
    font-weight: bold;
    margin: 30px 0;
    text-shadow: 0 4px 20px rgba(0, 0, 0, 0.4);
}

.confetti {
    font-size: 2.5rem;
    animation: bounce 1s ease-in-out infinite;
}

@keyframes bounce {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-20px); }
}

.results-content {
    max-width: 1000px;
    margin: 0 auto;
}

.results-section {
    background: var(--card-bg);
    padding: 30px;
    border-radius: 15px;
    box-shadow: var(--shadow);
    margin-bottom: 30px;
}

.results-section h2 {
    color: var(--text-primary);
    margin-bottom: 25px;
}

.summary-stats {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 20px;
}

.stat-box {
    background: var(--light-bg);
    padding: 25px;
    border-radius: 12px;
    text-align: center;
}

.stat-label {
    color: var(--text-secondary);
    font-size: 0.95rem;
    margin-bottom: 10px;
}

.stat-value {
    font-size: 2.5rem;
    font-weight: bold;
    color: var(--primary-color);
}

.match-history {
    display: flex;
    flex-direction: column;
    gap: 15px;
}

.round-header {
    font-weight: bold;
    color: var(--primary-color);
    font-size: 1.2rem;
    margin-top: 10px;
    padding-top: 10px;
    border-top: 2px solid var(--border-color);
}

.round-header:first-child {
    margin-top: 0;
    padding-top: 0;
    border-top: none;
}

.history-match {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 15px 20px;
    background: var(--light-bg);
    border-radius: 10px;
}

.history-players {
    color: var(--text-primary);
    font-weight: 500;
}

.history-winner {
    color: var(--success-color);
    font-weight: 600;
}

.results-actions {
    display: flex;
    justify-content: center;
    gap: 20px;
    margin-top: 40px;
}

/* Responsive Design for SPA */
@media (max-width: 1024px) {
    .tournament-content {
        grid-template-columns: 1fr;
    }

    .match-info-panel {
        order: 2;
    }

    .game-area {
        order: 1;
    }

    .tournament-preview-card {
        flex-direction: column;
        text-align: center;
    }

    .profile-snapshot-card {
        flex-direction: column;
        text-align: center;
    }

    .profile-stats {
        justify-content: center;
    }
}

@media (max-width: 768px) {
    .welcome-title {
        font-size: 2.5rem;
    }

    .welcome-text {
        font-size: 1.1rem;
    }

    .section-title {
        font-size: 1.6rem;
    }

    .section-header {
        flex-direction: column;
        gap: 15px;
        align-items: flex-start;
    }

    .play-options-grid {
        grid-template-columns: 1fr;
    }

    .leaderboard-header {
        grid-template-columns: 60px 1fr 100px;
        font-size: 0.8rem;
        padding: 12px 15px;
    }

    .leaderboard-item {
        grid-template-columns: 60px 1fr 100px;
        padding: 12px 15px;
    }

    .leaderboard-item .rank {
        font-size: 1rem;
    }

    .profile-snapshot-card {
        padding: 25px;
    }

    .profile-info h3 {
        font-size: 1.5rem;
    }

    .profile-stats {
        flex-direction: row;
        gap: 20px;
        flex-wrap: wrap;
    }

    .stat-value {
        font-size: 1.5rem;
    }

    .info-cards-grid {
        grid-template-columns: repeat(2, 1fr);
    }

    .home-title {
        font-size: 3rem;
    }

    .home-subtitle {
        font-size: 1.2rem;
    }

    .home-menu {
        flex-direction: column;
    }

    .menu-btn {
        min-width: auto;
        padding: 30px;
    }

    .menu-btn-icon {
        font-size: 3rem;
    }

    .menu-btn-text {
        font-size: 1.5rem;
    }

    .score-display {
        padding: 15px 30px;
        gap: 20px;
    }

    .score-number {
        font-size: 2rem;
    }

    #pongCanvas {
        max-width: 100%;
        height: auto;
    }

    .game-controls-info {
        flex-direction: column;
        gap: 10px;
        font-size: 0.85rem;
    }

    .tournament-setup-content {
        padding: 25px;
    }

    .champion-banner h1 {
        font-size: 2rem;
    }

    .champion-name {
        font-size: 2.5rem;
    }
}

@media (max-width: 480px) {
    .welcome-section {
        padding: 40px 15px;
    }

    .welcome-title {
        font-size: 2rem;
    }

    .welcome-text {
        font-size: 1rem;
    }

    .section-title {
        font-size: 1.4rem;
    }

    .play-option-card {
        padding: 25px 20px;
    }

    .play-icon {
        font-size: 2.5rem;
    }

    .play-option-card h3 {
        font-size: 1.3rem;
    }

    .tournament-preview-card {
        padding: 25px 20px;
    }

    .tournament-info h3 {
        font-size: 1.4rem;
    }

    .leaderboard-preview-card {
        padding: 20px 15px;
    }

    .leaderboard-header {
        display: none;
    }

    .leaderboard-item {
        grid-template-columns: 50px 1fr 80px;
        padding: 10px 12px;
        gap: 10px;
    }

    .profile-snapshot-card {
        padding: 20px 15px;
    }

    .profile-avatar .avatar-circle {
        width: 80px;
        height: 80px;
        font-size: 2.5rem;
    }

    .profile-info h3 {
        font-size: 1.3rem;
        margin-bottom: 15px;
    }

    .profile-stats {
        gap: 15px;
    }

    .stat-value {
        font-size: 1.3rem;
    }

    .info-cards-grid {
        grid-template-columns: 1fr;
    }

    .game-header-bar {
        flex-direction: column;
        gap: 10px;
    }

    .tournament-header {
        flex-direction: column;
    }
}
