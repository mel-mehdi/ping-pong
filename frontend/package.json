{
  "name": "ping-pong-game",
  "version": "1.0.0",
  "description": "A responsive, accessible web-based Ping Pong game",
  "main": "pages/login.html",
  "type": "module",
  "scripts": {
    "build": "babel ts --out-dir dist --extensions '.ts' --copy-files && find dist -name '*.js' -type f -exec sed -i 's/\\.ts\"/\\.js\"/g' {} +",
    "dev": "npm run build && npx http-server -p 8000 -o pages/login.html",
    "start": "npm run build && npx http-server -p 8000",
    "lint": "eslint scripts/**/*.js",
    "lint:fix": "eslint scripts/**/*.js --fix",
    "format": "prettier --write \"**/*.{js,html,css,md}\"",
    "format:check": "prettier --check \"**/*.{js,html,css,md}\"",
    "validate": "npm run lint && npm run format:check"
  },
  "keywords": [
    "ping-pong",
    "game",
    "html5",
    "canvas",
    "accessibility",
    "responsive"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@babel/cli": "^7.28.3",
    "@babel/core": "^7.28.5",
    "@babel/preset-env": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@types/node": "^24.10.1",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "http-server": "^14.1.1",
    "prettier": "^3.2.4",
    "typescript": "^5.9.3"
  }
}
